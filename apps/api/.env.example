# Скопируйте в .env и подставьте значения. Не коммитьте .env с секретами.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL (локально или на сервере). Без URL /health/ready вернёт not_configured.
DATABASE_URL=postgresql://birzha:birzha@localhost:5432/birzha

# Подпись JWT для /auth/*; обязателен вместе с DATABASE_URL (≥ 32 символов).
# JWT_SECRET=

# Требовать JWT + роли на партиях/рейсах/sync (1 / true). Пока UI без входа — обычно выкл.
# REQUIRE_API_AUTH=false

# Интеграционные тесты репозитория (pnpm --filter @birzha/api test). Если не задан — тесты с БД пропускаются.
# TEST_DATABASE_URL=postgresql://birzha:birzha@localhost:5432/birzha
